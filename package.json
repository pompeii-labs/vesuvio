{
  "name": "@pompeii-labs/vesuvio",
  "version": "0.1.0",
  "description": "Local AI agent daemon — one brain, multiple workstreams",
  "type": "module",
  "bin": {
    "vesuvio": "src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "daemon": "bun src/daemon/index.ts",
    "dev": "bun --watch src/cli.ts",
    "dev:daemon": "bun --watch src/daemon/index.ts",
    "build:binary": "bun build --compile src/cli.ts --outfile dist/vesuvio",
    "lint": "eslint src/ --max-warnings=0",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@luxdb/sdk": "^1.2.0",
    "@pompeii-labs/magma": "^1.8.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "string-width": "^8.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bun-types": "latest",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "react-devtools-core": "^7.0.1",
    "typescript-eslint": "^8.58.0"
  },
  "license": "MIT"
}
